generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Настройки гильдии ────────────────────────
model GuildSettings {
  id        String   @id @default(cuid())
  guildId   String   @unique
  locale    String   @default("ru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guild_settings")
}

// ── Пользователь ─────────────────────────────
model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  locale    String   @default("ru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Лог модулей ──────────────────────────────
model ModuleLog {
  id         String   @id @default(cuid())
  moduleName String
  action     String   // load | unload | reload | error
  details    String?
  createdAt  DateTime @default(now())

  @@map("module_logs")
}

// ═══════════════════════════════════════════════
//  Временные голосовые каналы (TempVoice)
// ═══════════════════════════════════════════════

// ── Генератор (настройки «канала-создателя») ──
model TempVoiceGenerator {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String   @unique                    // голосовой канал-триггер
  categoryId     String                              // категория для новых каналов
  interfaceId    String?                             // текстовый канал с панелью управления

  // Шаблон имени: {username}, {nickname}, {game}, {count}
  defaultName    String   @default("{nickname}")
  defaultLimit   Int      @default(0)                // 0 = без лимита  
  defaultBitrate Int      @default(64000)
  defaultRegion  String   @default("auto")
  initialState   String   @default("unlocked")       // unlocked | locked | hidden

  // Ограничения (антиабьюз)
  maxChannelsPerUser Int  @default(1)
  maxUserLimit       Int  @default(99)
  minUserLimit       Int  @default(0)
  maxBitrate         Int  @default(96000)
  minBitrate         Int  @default(8000)

  // Роли
  immuneRoleIds  String[] @default([])               // модераторские роли — обходят все ограничения
  boosterPerks   Boolean  @default(true)             // бустеры получают расширенные права

  // Наградная роль
  rewardRoleId       String?                         // роль для самых активных пользователей войсов
  rewardThresholdMin Int      @default(3000)          // порог в минутах (3000 = 50ч)
  rewardAnnounceChId String?                          // канал для объявлений о наградах

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channels       TempVoiceChannel[]

  @@index([guildId])
  @@map("tempvoice_generators")
}

// ── Активный временный голосовой канал ────────
model TempVoiceChannel {
  id             String   @id                        // Discord channel ID
  guildId        String
  ownerId        String                              // текущий владелец
  generatorId    String
  generator      TempVoiceGenerator @relation(fields: [generatorId], references: [id], onDelete: Cascade)

  state          String   @default("unlocked")       // unlocked | locked | hidden
  controlMsgId   String?                             // ID сообщения с панелью в текстовом чате VC

  // Антиспам переименований
  nameChanges    Int      @default(0)
  lastNameChange DateTime?

  createdAt      DateTime @default(now())
  lastActivity   DateTime @default(now())

  trusted        TempVoiceTrust[]
  blocked        TempVoiceBlock[]

  @@index([guildId])
  @@index([ownerId])
  @@map("tempvoice_channels")
}

// ── Доверенные пользователи канала ────────────
model TempVoiceTrust {
  id        String           @id @default(cuid())
  channelId String
  channel   TempVoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([channelId, userId])
  @@map("tempvoice_trusted")
}

// ── Заблокированные пользователи канала ───────
model TempVoiceBlock {
  id        String           @id @default(cuid())
  channelId String
  channel   TempVoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([channelId, userId])
  @@map("tempvoice_blocked")
}

// ── Сохранённые настройки пользователя ────────
model TempVoiceUserSettings {
  id        String  @id @default(cuid())
  userId    String
  guildId   String

  savedName    String?
  savedLimit   Int?
  savedBitrate Int?
  savedRegion  String?

  // Статистика войса (для наградной роли)
  totalVoiceMinutes Int @default(0)
  rewardGranted     Boolean @default(false)

  @@unique([userId, guildId])
  @@map("tempvoice_user_settings")
}

// ═══════════════════════════════════════════════
//  Отпуска (Vacation)
// ═══════════════════════════════════════════════

// ── Конфигурация системы отпусков ─────────────
model VacationConfig {
  id              String   @id @default(cuid())
  guildId         String   @unique

  panelChannelId  String?                             // канал где размещена панель
  panelMessageId  String?                             // ID сообщения панели

  reviewChannelId String?                             // канал для заявок (ревью)
  logChannelId    String?                             // канал для логов (одобрено/вернулся)

  vacationRoleId  String?                             // роль, выдаваемая в отпуске
  removeRoleIds   String[]  @default([])              // роли, снимаемые при уходе в отпуск
  reviewerRoleIds String[]  @default([])              // роли, которые могут одобрять/отклонять
  pingRoleIds     String[]  @default([])              // роли, пингуемые при новой заявке

  maxDurationDays Int       @default(30)              // максимальная длительность в днях
  quickDurationH  Int       @default(12)              // длительность «Не смогу сегодня» в часах

  // Антиабьюз
  cooldownDays    Int       @default(7)               // дней кулдауна после возврата из отпуска
  maxPerMonth     Int       @default(3)               // макс. отпусков за 30 дней
  maxQuickPerWeek Int       @default(2)               // макс. быстрых отпусков за 7 дней

  primeTimeStart  Int       @default(17)              // начало прайм-тайма (МСК, 0-23)
  primeTimeEnd    Int       @default(1)               // конец прайм-тайма (МСК, 0-23)
  primeTimeBuffer Int       @default(1)               // блокировка за N ч до прайм-тайма

  imageUrl        String?                             // картинка для панели

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  requests        VacationRequest[]

  @@map("vacation_configs")
}

// ── Заявка на отпуск ──────────────────────────
model VacationRequest {
  id              String    @id @default(cuid())
  guildId         String
  userId          String

  type            String    @default("regular")       // regular | quick | admin
  reason          String
  durationMinutes Int                                 // запрашиваемая длительность

  status          String    @default("pending")       // pending | active | denied | expired | completed
  reviewerId      String?                             // кто одобрил/отклонил
  reviewMessageId String?                             // ID сообщения в канале ревью

  savedRoleIds    String[]  @default([])              // роли, снятые при уходе (для восстановления)

  startDate       DateTime?                           // начало отпуска (после одобрения)
  endDate         DateTime?                           // окончание отпуска
  reminderSent    Boolean   @default(false)           // напоминание за 24ч отправлено?

  configId        String
  config          VacationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([guildId, userId])
  @@index([status])
  @@map("vacation_requests")
}

// ═══════════════════════════════════════════════
//  Полковые бои (RegBattle)
// ═══════════════════════════════════════════════

// ── Конфигурация системы ПБ ───────────────────
model RegBattleConfig {
  id                String   @id @default(cuid())
  guildId           String   @unique

  masterChannelId   String?                             // канал-генератор (войс для создания отрядов)
  categoryId        String?                             // категория для временных каналов ПБ
  announceChannelId String?                             // канал для пингов/объявлений
  reserveChannelId  String?                             // войс канал запасных

  pingRoleId        String?                             // роль для пинга доступных бойцов
  inSquadRoleId     String?                             // роль «в отряде» (снимает пинг-роль)
  commanderRoleIds  String[] @default([])               // роли полевых командиров (доступ к генератору)
  muteRoleIds       String[] @default([])               // роли, мьютящиеся по кнопке «Распоряжения»

  reprimandChannelId String?                            // канал для выговоров
  reprimandAnnulRoleIds String[] @default([])           // роли, которые могут аннулировать выговоры
  reprimandTypeRoleIds  String[] @default([])           // роли-типы выговоров (для выбора)

  squadSize         Int      @default(8)                // целевой размер отряда
  airSize           Int      @default(4)                // макс. людей в авиа-канале

  pingEscalateAfter Int     @default(6)                 // сколько пингов роли до эскалации к именным

  playedTodayRoleId String?                             // роль «Играл сегодня» (не пингуется до сброса)
  playedMinMinutes  Int      @default(15)               // мин. минут в ПБ-войсе для получения роли
  playedResetHour   Int      @default(23)               // час сброса роли (МСК, 0-23)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  squads            RegBattleSquad[]

  @@map("regbattle_configs")
}

// ── Активный отряд (временный голосовой канал) ─
model RegBattleSquad {
  id              String   @id @default(cuid())
  guildId         String
  number          Int                                   // номер отряда (1, 2, …)

  voiceChannelId  String   @unique                      // основной голосовой канал
  airChannelId    String?                               // авиационный суб-канал (привязан к основному)

  panelMessageId  String?                               // ID сообщения с панелью управления
  ownerId         String                                // текущий владелец (полевой командир)

  createdAt       DateTime @default(now())

  configId        String
  config          RegBattleConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@map("regbattle_squads")
}

// ── Выговор (дисциплинарная система ПБ) ───────
model Reprimand {
  id              String   @id @default(cuid())
  guildId         String

  offenderId      String                                // ID нарушителя
  issuerId        String                                // ID выдавшего выговор
  typeRoleId      String                                // роль-тип выговора
  reason          String                                // причина

  status          String   @default("active")           // active | appealing | annulled
  messageId       String?                               // ID сообщения в канале выговоров
  channelId       String?                               // ID канала выговоров (на момент создания)

  appealCategoryId String?                              // категория апелляции
  appealTextId    String?                               // текстовый канал апелляции
  appealVoiceId   String?                               // голосовой канал апелляции

  annulledById    String?                               // кто аннулировал
  annulledAt      DateTime?                             // когда аннулировано

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([guildId])
  @@index([offenderId])
  @@map("reprimands")
}

// ═══════════════════════════════════════════════
//  Экономика (Economy) — шекели ₪
// ═══════════════════════════════════════════════

// ── Конфигурация экономики для гильдии ────────
model EconomyConfig {
  id              String   @id @default(cuid())
  guildId         String   @unique

  enabled         Boolean  @default(true)               // экономика включена?
  newsChannelId   String?                               // канал новостей экономики
  logChannelId    String?                               // канал логов (админский)

  // Войс-заработок
  voiceRateBase   Int      @default(50)                 // ₪/ч в обычных войсах
  voiceRatePb     Int      @default(200)                // ₪/ч в ПБ-войсах
  voiceMinMembers Int      @default(2)                  // мин. людей в войсе для начислений
  voiceIntervalMs Int      @default(600000)             // интервал начислений (10 мин)

  // Кулдауны (мс)
  dailyCooldown   BigInt   @default(86400000)           // 24ч
  weeklyCooldown  BigInt   @default(604800000)          // 7д
  workCooldown    BigInt   @default(14400000)            // 4ч
  crimeCooldown   BigInt   @default(28800000)           // 8ч
  begCooldown     BigInt   @default(30000)              // 30с

  // Заработок
  dailyBase       Int      @default(500)                // базовый дейли
  dailyStreakAdd  Int      @default(50)                 // бонус за стрик (+₪50/день)
  dailyStreakMax  Int      @default(500)                // макс. бонус стрика
  weeklyBase      Int      @default(5000)               // базовый викли
  weeklyPbBonus   Int      @default(2000)               // бонус если играл ПБ на неделе
  workMin         Int      @default(200)                // мин. за работу
  workMax         Int      @default(800)                // макс. за работу
  crimeMin        Int      @default(0)                  // мин. за преступление
  crimeMax        Int      @default(2000)               // макс. за преступление
  crimeSuccessRate Int     @default(60)                 // шанс успеха (%)
  crimeFine       Int      @default(500)                // штраф при провале
  begMin          Int      @default(5)                  // мин. подаяние
  begMax          Int      @default(100)                // макс. подаяние

  // Переводы
  transferTax     Int      @default(5)                  // налог на переводы (%)
  bankWithdrawTax Int      @default(2)                  // комиссия за снятие из банка (%)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("economy_configs")
}

// ── Профиль экономики пользователя ────────────
model EconomyProfile {
  id              String    @id @default(cuid())
  guildId         String
  userId          String

  wallet          Int       @default(0)                 // наличные (кошелёк)
  bank            Int       @default(0)                 // банковский счёт
  bankLimit       Int       @default(5000)              // лимит банка (привязан к ПБ-роли)

  dailyStreak     Int       @default(0)                 // текущий стрик дейли
  bestDailyStreak Int       @default(0)                 // лучший стрик за всё время

  lastDaily       DateTime?                             // последний /daily
  lastWeekly      DateTime?                             // последний /weekly
  lastWork        DateTime?                             // последний /work
  lastCrime       DateTime?                             // последний /crime
  lastBeg         DateTime?                             // последний /beg
  lastRob         DateTime?                             // последний /rob

  totalEarned     BigInt    @default(0)                 // всего заработано
  totalSpent      BigInt    @default(0)                 // всего потрачено

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    EconomyTransaction[]

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("economy_profiles")
}

// ── Транзакция экономики ──────────────────────
model EconomyTransaction {
  id          String   @id @default(cuid())
  guildId     String
  userId      String

  type        String                                    // earn_daily, earn_work, earn_voice, transfer_out, transfer_in, rob_success, rob_fail, fine, etc.
  amount      Int                                       // +/- сумма
  balance     Int                                       // баланс после транзакции (wallet)

  targetId    String?                                   // другой пользователь (перевод, ограбление)
  details     String?                                   // доп. информация

  profileId   String
  profile     EconomyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([guildId, userId])
  @@index([createdAt])
  @@map("economy_transactions")
}
