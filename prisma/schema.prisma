generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Core ---

model GuildSettings {
  id        String   @id @default(cuid())
  guildId   String   @unique
  locale    String   @default("ru")
  prefix    String   @default("/")

  // welcome & roles
  welcomeChannelId String?
  ticketChannelId  String?
  autoRoleId       String?
  recruitRoleId    String?
  memberRoleId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guild_settings")
}

model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  locale    String   @default("ru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ModuleLog {
  id         String   @id @default(cuid())
  moduleName String
  action     String
  details    String?
  createdAt  DateTime @default(now())

  @@map("module_logs")
}

// --- Economy ---

model EconomyConfig {
  id                String   @id @default(cuid())
  guildId           String   @unique
  enabled           Boolean  @default(true)
  newsChannelId     String?
  logChannelId      String?

  // Voice rewards
  voiceRateBase     Int      @default(50)
  voiceRatePb       Int      @default(200)
  voiceMinMembers   Int      @default(2)
  voiceIntervalMs   Int      @default(600000)

  // Cooldowns (ms)
  dailyCooldown     BigInt   @default(86400000)
  weeklyCooldown    BigInt   @default(604800000)
  workCooldown      BigInt   @default(14400000)
  crimeCooldown     BigInt   @default(28800000)
  begCooldown       BigInt   @default(30000)

  // Rewards
  dailyBase         Int      @default(500)
  dailyStreakAdd    Int      @default(50)
  dailyStreakMax    Int      @default(500)
  weeklyBase        Int      @default(5000)
  weeklyPbBonus     Int      @default(2000)
  workMin           Int      @default(200)
  workMax           Int      @default(800)
  crimeMin          Int      @default(0)
  crimeMax          Int      @default(2000)
  crimeSuccessRate  Int      @default(60)
  crimeFine         Int      @default(500)
  begMin            Int      @default(5)
  begMax            Int      @default(100)

  // Taxes
  transferTax       Int      @default(5)
  bankWithdrawTax   Int      @default(2)

  // Casino
  casinoEnabled     Boolean  @default(true)
  casinoMaxBet      Int      @default(50000)
  casinoMinBet      Int      @default(50)

  // PB roles
  pbRoleIds         String[] @default([])

  // Rob
  robCooldown       BigInt   @default(14400000)
  robEnabled        Boolean  @default(true)
  robFine           Int      @default(500)
  robMaxPercent     Int      @default(30)
  robMinSteal       Int      @default(100)
  robSuccessRate    Int      @default(45)

  // Shop
  shopEnabled       Boolean  @default(true)

  // Auto-leaderboard
  leaderboardChannelId  String?
  leaderboardMessageId  String?

  // Welcome bonus (0 = disabled)
  welcomeBonus      Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  shopItems         ShopItem[]

  @@map("economy_configs")
}

model EconomyProfile {
  id              String    @id @default(cuid())
  guildId         String
  userId          String
  wallet          Int       @default(0)
  bank            Int       @default(0)
  bankLimit       Int       @default(5000)
  dailyStreak     Int       @default(0)
  bestDailyStreak Int       @default(0)
  lastDaily       DateTime?
  lastWeekly      DateTime?
  lastWork        DateTime?
  lastCrime       DateTime?
  lastBeg         DateTime?
  lastRob         DateTime?
  totalEarned     BigInt    @default(0)
  totalSpent      BigInt    @default(0)
  pbVoiceSeconds  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    EconomyTransaction[]

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("economy_profiles")
}

model EconomyTransaction {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  type      String
  amount    Int
  balance   Int
  targetId  String?
  details   String?
  profileId String
  createdAt DateTime @default(now())

  profile   EconomyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([createdAt])
  @@map("economy_transactions")
}

// --- Shop ---

model ShopItem {
  id           String   @id @default(cuid())
  guildId      String
  roleId       String
  name         String
  description  String?
  price        Int
  durationHours Int     @default(0)
  maxStock     Int      @default(-1)
  currentStock Int      @default(-1)
  isActive     Boolean  @default(true)
  configId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  config       EconomyConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  purchases    ShopPurchase[]

  @@unique([guildId, roleId])
  @@index([guildId])
  @@map("shop_items")
}

model ShopPurchase {
  id        String    @id @default(cuid())
  guildId   String
  userId    String
  itemId    String
  price     Int
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  item      ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([expiresAt])
  @@map("shop_purchases")
}

// --- RegBattle ---

model RegbattleConfig {
  id                   String   @id @default(cuid())
  guildId              String   @unique
  masterChannelId      String?
  categoryId           String?
  announceChannelId    String?
  reserveChannelId     String?
  pingRoleId           String?
  inSquadRoleId        String?
  commanderRoleIds     String[] @default([])
  muteRoleIds          String[] @default([])
  squadSize            Int      @default(8)
  airSize              Int      @default(4)
  pingEscalateAfter    Int      @default(6)
  playedMinMinutes     Int      @default(15)
  playedResetHour      Int      @default(23)
  playedTodayRoleId    String?
  reprimandAnnulRoleIds  String[] @default([])
  reprimandChannelId    String?
  reprimandTypeRoleIds  String[] @default([])
  reprimandDurationDays Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  squads               RegbattleSquad[]

  @@map("regbattle_configs")
}

model RegbattleSquad {
  id              String   @id @default(cuid())
  guildId         String
  number          Int
  voiceChannelId  String   @unique
  airChannelId    String?
  panelMessageId  String?
  ownerId         String
  createdAt       DateTime @default(now())
  configId        String

  config          RegbattleConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@map("regbattle_squads")
}

// --- Reprimands ---

model Reprimand {
  id                    String    @id @default(cuid())
  guildId               String
  offenderId            String
  issuerId              String
  typeRoleId            String
  reason                String
  status                String    @default("active")
  messageId             String?
  channelId             String?
  appealCategoryId      String?
  appealTextId          String?
  appealVoiceId         String?
  annulledById          String?
  annulledAt            DateTime?
  expiresAt             DateTime?
  nextAppealAt          DateTime?
  appealDecision        String?
  appealDecisionById    String?
  appealDecisionReason  String?
  appealDecisionAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([guildId])
  @@index([offenderId])
  @@index([expiresAt])
  @@map("reprimands")
}

// --- TempVoice ---

model TempvoiceGenerator {
  id                  String   @id @default(cuid())
  guildId             String
  channelId           String   @unique
  categoryId          String
  interfaceId         String?
  defaultName         String   @default("{nickname}")
  defaultLimit        Int      @default(0)
  defaultBitrate      Int      @default(64000)
  defaultRegion       String   @default("auto")
  initialState        String   @default("unlocked")
  maxChannelsPerUser  Int      @default(1)
  maxUserLimit        Int      @default(99)
  minUserLimit        Int      @default(0)
  maxBitrate          Int      @default(96000)
  minBitrate          Int      @default(8000)
  boosterPerks        Boolean  @default(true)
  immuneRoleIds       String[] @default([])
  rewardAnnounceChId  String?
  rewardRoleId        String?
  rewardThresholdMin  Int      @default(3000)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  channels            TempvoiceChannel[]

  @@index([guildId])
  @@map("tempvoice_generators")
}

model TempvoiceChannel {
  id             String    @id @default(cuid())
  guildId        String
  ownerId        String
  generatorId    String
  state          String    @default("unlocked")
  controlMsgId   String?
  nameChanges    Int       @default(0)
  lastNameChange DateTime?
  createdAt      DateTime  @default(now())
  lastActivity   DateTime  @default(now())

  generator      TempvoiceGenerator @relation(fields: [generatorId], references: [id], onDelete: Cascade)
  blocked        TempvoiceBlocked[]
  trusted        TempvoiceTrusted[]

  @@index([guildId])
  @@index([ownerId])
  @@map("tempvoice_channels")
}

model TempvoiceBlocked {
  id        String @id @default(cuid())
  channelId String
  userId    String

  channel   TempvoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("tempvoice_blocked")
}

model TempvoiceTrusted {
  id        String @id @default(cuid())
  channelId String
  userId    String

  channel   TempvoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("tempvoice_trusted")
}

model TempvoiceUserSettings {
  id                String   @id @default(cuid())
  userId            String
  guildId           String
  savedName         String?
  savedLimit        Int?
  savedBitrate      Int?
  savedRegion       String?
  rewardGranted     Boolean  @default(false)
  totalVoiceMinutes Int      @default(0)

  @@unique([userId, guildId])
  @@map("tempvoice_user_settings")
}

// --- Vacation ---

model VacationConfig {
  id               String   @id @default(cuid())
  guildId          String   @unique
  panelChannelId   String?
  panelMessageId   String?
  reviewChannelId  String?
  logChannelId     String?
  vacationRoleId   String?
  removeRoleIds    String[] @default([])
  reviewerRoleIds  String[] @default([])
  pingRoleIds      String[] @default([])
  maxDurationDays  Int      @default(30)
  quickDurationH   Int      @default(12)
  primeTimeStart   Int      @default(17)
  primeTimeEnd     Int      @default(1)
  primeTimeBuffer  Int      @default(1)
  imageUrl         String?
  autoDenyHours    Int      @default(8)
  cooldownDays     Int      @default(3)
  maxPerMonth      Int      @default(5)
  maxQuickPerWeek  Int      @default(2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  requests         VacationRequest[]

  @@map("vacation_configs")
}

model VacationRequest {
  id              String    @id @default(cuid())
  guildId         String
  userId          String
  type            String    @default("regular")
  reason          String
  durationMinutes Int
  status          String    @default("pending")
  reviewerId      String?
  reviewMessageId String?
  savedRoleIds    String[]  @default([])
  startDate       DateTime?
  endDate         DateTime?
  reminderSent    Boolean   @default(false)
  configId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  config          VacationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([status])
  @@map("vacation_requests")
}

// --- Небесные Стражи ---

model NsVacation {
  id           String   @id @default(cuid())
  guildId      String
  userId       String
  type         String   // shield (4ч, ПБ-щит) | troll (10мин, рофл) | vacation (отпуск, без ролей)
  savedRoleIds String[] @default([])
  status       String   @default("active") // active | completed
  reason       String?
  messageId    String?  // ID лог-сообщения (для vacation type)
  startDate    DateTime @default(now())
  endDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([guildId, userId])
  @@index([status, endDate])
  @@map("ns_vacations")
}

// --- BR (Боевые рейтинги) ---

model BrTechEntry {
  id        Int      @id @default(autoincrement())
  guildId   String
  br        String   // "4.0", "10.3"
  category  String   // tanks | planes | helis | spaa
  priority  String   // high | normal | low
  name      String
  createdAt DateTime @default(now())

  @@index([guildId, br])
  @@index([guildId, br, category])
  @@index([guildId, name])
  @@map("br_tech_entries")
}

model BrPanel {
  id              String   @id @default(cuid())
  guildId         String   @unique
  panelChannelId  String?
  panelMessageId  String?
  defaultBr       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("br_panels")
}

// --- Teams (PB Team System) ---

model TeamConfig {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  applicationChannelId String? // Канал для заявок на создание команды
  reportChannelId     String?  // Канал для отчётов после сессий
  pollChannelId       String?  // Канал для опросов/сборов
  leaderboardChannelId String? // Канал для лидерборда
  leaderboardMessageId String? // ID сообщения лидерборда (авто-обновление)
  approverRoleIds     String[] @default([]) // Роли, одобряющие заявки
  baseRoleId          String?  // Базовая роль (кто может создавать/вступать)
  minSize             Int      @default(10)  // Минимальный размер команды
  inviteTimeoutH      Int      @default(24)  // Таймаут инвайта (часы)
  formationDays       Int      @default(7)   // Дней на формирование команды
  disbandGraceDays    Int      @default(30)  // Дней до расформирования при < minSize
  pollAutoHoursBefore Int      @default(2)   // За сколько часов до прайма авто-опрос
  reportTimeoutH      Int      @default(3)   // Таймаут на заполнение отчёта (часы)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  teams               Team[]

  @@map("team_configs")
}

model Team {
  id               String    @id @default(cuid())
  guildId          String
  name             String
  roleId           String    @unique // Discord роль команды
  leaderId         String    // Лидер команды
  status           String    @default("forming") // forming | active | disbanding | disbanded
  disbandWarningAt DateTime? // Дата начала предупреждения о расформировании
  configId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  config           TeamConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  members          TeamMember[]
  invites          TeamInvite[]
  applications     TeamApplication[]
  sessions         TeamSession[]
  seasonStats      TeamSeason[]
  polls            TeamPoll[]

  @@unique([guildId, name])
  @@index([guildId])
  @@index([leaderId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique // Один человек — одна команда
  joinedAt DateTime @default(now())

  team     Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("team_members")
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  status    String   @default("pending") // pending | accepted | declined | expired
  messageId String?  // ID DM-сообщения с инвайтом
  expiresAt DateTime
  createdAt DateTime @default(now())

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([expiresAt])
  @@map("team_invites")
}

model TeamApplication {
  id              String   @id @default(cuid())
  teamId          String
  status          String   @default("pending") // pending | approved | rejected
  messageId       String?  // ID сообщения в канале заявок
  reviewerId      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  team            Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
  @@map("team_applications")
}

model TeamSession {
  id           String    @id @default(cuid())
  teamId       String
  guildId      String
  squadNumber  Int?      // Номер отряда ПБ
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  reportedById String?   // Кто заполнил отчёт
  reportedPR   Int?      // Полковой рейтинг за сессию
  reportedPlace Int?     // Место полка
  reportedAt   DateTime?
  createdAt    DateTime  @default(now())

  team         Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([guildId, startedAt])
  @@map("team_sessions")
}

model TeamSeason {
  id            String @id @default(cuid())
  teamId        String
  season        Int    // 1-6 (Янв-Фев, Мар-Апр, ..., Ноя-Дек)
  year          Int    // 2026, 2027...
  totalPR       Int    @default(0)
  totalSessions Int    @default(0)
  totalPlace    Int    @default(0) // Сумма мест для расчёта среднего
  bestPlace     Int    @default(300)
  attendance    Int    @default(0) // Общее число участников за сезон (суммарно по сессиям)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team          Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season, year])
  @@index([year, season])
  @@map("team_seasons")
}

model TeamPoll {
  id          String   @id @default(cuid())
  teamId      String
  messageId   String?  // ID сообщения опроса
  channelId   String?  // Канал, где опрос
  type        String   @default("manual") // manual | auto
  scheduledAt DateTime?// Время ПБ (указанное лидером)
  yesUserIds  String[] @default([])
  noUserIds   String[] @default([])
  voteTimes   Json     @default("{}") // { "userId": "18:00", ... } — время готовности каждого
  status      String   @default("active") // active | closed
  createdAt   DateTime @default(now())

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
  @@map("team_polls")
}
