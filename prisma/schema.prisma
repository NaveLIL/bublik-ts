generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Настройки гильдии ────────────────────────
model GuildSettings {
  id        String   @id @default(cuid())
  guildId   String   @unique
  locale    String   @default("ru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guild_settings")
}

// ── Пользователь ─────────────────────────────
model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  locale    String   @default("ru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Лог модулей ──────────────────────────────
model ModuleLog {
  id         String   @id @default(cuid())
  moduleName String
  action     String   // load | unload | reload | error
  details    String?
  createdAt  DateTime @default(now())

  @@map("module_logs")
}

// ═══════════════════════════════════════════════
//  Временные голосовые каналы (TempVoice)
// ═══════════════════════════════════════════════

// ── Генератор (настройки «канала-создателя») ──
model TempVoiceGenerator {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String   @unique                    // голосовой канал-триггер
  categoryId     String                              // категория для новых каналов
  interfaceId    String?                             // текстовый канал с панелью управления

  // Шаблон имени: {username}, {nickname}, {game}, {count}
  defaultName    String   @default("{nickname}")
  defaultLimit   Int      @default(0)                // 0 = без лимита  
  defaultBitrate Int      @default(64000)
  defaultRegion  String   @default("auto")
  initialState   String   @default("unlocked")       // unlocked | locked | hidden

  // Ограничения (антиабьюз)
  maxChannelsPerUser Int  @default(1)
  maxUserLimit       Int  @default(99)
  minUserLimit       Int  @default(0)
  maxBitrate         Int  @default(96000)
  minBitrate         Int  @default(8000)

  // Роли
  immuneRoleIds  String[] @default([])               // модераторские роли — обходят все ограничения
  boosterPerks   Boolean  @default(true)             // бустеры получают расширенные права

  // Наградная роль
  rewardRoleId       String?                         // роль для самых активных пользователей войсов
  rewardThresholdMin Int      @default(3000)          // порог в минутах (3000 = 50ч)
  rewardAnnounceChId String?                          // канал для объявлений о наградах

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channels       TempVoiceChannel[]

  @@index([guildId])
  @@map("tempvoice_generators")
}

// ── Активный временный голосовой канал ────────
model TempVoiceChannel {
  id             String   @id                        // Discord channel ID
  guildId        String
  ownerId        String                              // текущий владелец
  generatorId    String
  generator      TempVoiceGenerator @relation(fields: [generatorId], references: [id], onDelete: Cascade)

  state          String   @default("unlocked")       // unlocked | locked | hidden
  controlMsgId   String?                             // ID сообщения с панелью в текстовом чате VC

  // Антиспам переименований
  nameChanges    Int      @default(0)
  lastNameChange DateTime?

  createdAt      DateTime @default(now())
  lastActivity   DateTime @default(now())

  trusted        TempVoiceTrust[]
  blocked        TempVoiceBlock[]

  @@index([guildId])
  @@index([ownerId])
  @@map("tempvoice_channels")
}

// ── Доверенные пользователи канала ────────────
model TempVoiceTrust {
  id        String           @id @default(cuid())
  channelId String
  channel   TempVoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([channelId, userId])
  @@map("tempvoice_trusted")
}

// ── Заблокированные пользователи канала ───────
model TempVoiceBlock {
  id        String           @id @default(cuid())
  channelId String
  channel   TempVoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([channelId, userId])
  @@map("tempvoice_blocked")
}

// ── Сохранённые настройки пользователя ────────
model TempVoiceUserSettings {
  id        String  @id @default(cuid())
  userId    String
  guildId   String

  savedName    String?
  savedLimit   Int?
  savedBitrate Int?
  savedRegion  String?

  // Статистика войса (для наградной роли)
  totalVoiceMinutes Int @default(0)
  rewardGranted     Boolean @default(false)

  @@unique([userId, guildId])
  @@map("tempvoice_user_settings")
}

// ═══════════════════════════════════════════════
//  Отпуска (Vacation)
// ═══════════════════════════════════════════════

// ── Конфигурация системы отпусков ─────────────
model VacationConfig {
  id              String   @id @default(cuid())
  guildId         String   @unique

  panelChannelId  String?                             // канал где размещена панель
  panelMessageId  String?                             // ID сообщения панели

  reviewChannelId String?                             // канал для заявок (ревью)
  logChannelId    String?                             // канал для логов (одобрено/вернулся)

  vacationRoleId  String?                             // роль, выдаваемая в отпуске
  removeRoleIds   String[]  @default([])              // роли, снимаемые при уходе в отпуск
  reviewerRoleIds String[]  @default([])              // роли, которые могут одобрять/отклонять
  pingRoleIds     String[]  @default([])              // роли, пингуемые при новой заявке

  maxDurationDays Int       @default(30)              // максимальная длительность в днях
  quickDurationH  Int       @default(12)              // длительность «Не смогу сегодня» в часах

  // Антиабьюз
  cooldownDays    Int       @default(7)               // дней кулдауна после возврата из отпуска
  maxPerMonth     Int       @default(3)               // макс. отпусков за 30 дней
  maxQuickPerWeek Int       @default(2)               // макс. быстрых отпусков за 7 дней

  primeTimeStart  Int       @default(17)              // начало прайм-тайма (МСК, 0-23)
  primeTimeEnd    Int       @default(1)               // конец прайм-тайма (МСК, 0-23)
  primeTimeBuffer Int       @default(1)               // блокировка за N ч до прайм-тайма

  imageUrl        String?                             // картинка для панели

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  requests        VacationRequest[]

  @@map("vacation_configs")
}

// ── Заявка на отпуск ──────────────────────────
model VacationRequest {
  id              String    @id @default(cuid())
  guildId         String
  userId          String

  type            String    @default("regular")       // regular | quick | admin
  reason          String
  durationMinutes Int                                 // запрашиваемая длительность

  status          String    @default("pending")       // pending | active | denied | expired | completed
  reviewerId      String?                             // кто одобрил/отклонил
  reviewMessageId String?                             // ID сообщения в канале ревью

  savedRoleIds    String[]  @default([])              // роли, снятые при уходе (для восстановления)

  startDate       DateTime?                           // начало отпуска (после одобрения)
  endDate         DateTime?                           // окончание отпуска
  reminderSent    Boolean   @default(false)           // напоминание за 24ч отправлено?

  configId        String
  config          VacationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([guildId, userId])
  @@index([status])
  @@map("vacation_requests")
}
