# ── Bublik Bot ─────────────────────────────────
# Discord
DISCORD_TOKEN=your_discord_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Если указать — команды (кроме глобальных) регистрируются только для этой гильдии
# Для продакшена оставить пустым — тогда guild-команды пушатся при guildCreate
DEV_GUILD_ID=

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://bublik:bublik_secret@postgres:5432/bublik?schema=public

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Bot Settings ──────────────────────────────
DEFAULT_LOCALE=ru
BOT_COLOR=#5865F2
LOG_LEVEL=info

# ── BR Rotation Test Config ───────────────────
# Тестовое расписание BR на 01.05.2026–30.06.2026.
# Вставь JSON в одну строку или используй /br rotation-update с файлом.
BR_ROTATION_DATA=[{"start":"2026-05-01","end":"2026-05-07","rating":"11.0"},{"start":"2026-05-08","end":"2026-05-14","rating":"10.0"},{"start":"2026-05-15","end":"2026-05-21","rating":"9.0"},{"start":"2026-05-22","end":"2026-05-28","rating":"8.0"},{"start":"2026-05-29","end":"2026-06-04","rating":"7.0"},{"start":"2026-06-05","end":"2026-06-11","rating":"6.0"},{"start":"2026-06-12","end":"2026-06-18","rating":"5.0"},{"start":"2026-06-19","end":"2026-06-25","rating":"4.0"},{"start":"2026-06-26","end":"2026-06-30","rating":"3.0"}]

# ── Environment ───────────────────────────────
NODE_ENV=production

# ── PostgreSQL (Docker Compose) ──────────────
POSTGRES_USER=bublik
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=bublik

# ── Welcome Module (каналы) ───────────────
# Канал куда отправляется приветствие
WELCOME_CHANNEL_ID=
# Канал тикетов
TICKET_CHANNEL_ID=
# Роль новобранца/кандидата (открывает доступ к каналу тикетов)
RECRUIT_ROLE_ID=

# ── Небесные Стражи (только для одной гильдии) ──
NS_GUILD_ID=